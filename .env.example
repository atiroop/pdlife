DB_HOST=localhost
DB_PORT=3306
DB_NAME=pdlife_pdlife-db
DB_USER=pdlife_pdlife-db-admin
DB_PASSWORD=
JWT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
APP_BASE_URL=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_CDN_BASE=
LOGO_URL=
LOGO_URL_DARK=

# cmd/db_backup only — a SEPARATE, private, non-CDN-fronted R2 bucket for
# database backups. Never reuse R2_BUCKET above for this: that bucket is
# served publicly via R2_CDN_BASE, and a DB dump must never be reachable
# there (see internal/r2store.BackupConfigFromEnv doc comment). Create a
# dedicated bucket with no public domain attached and put its name here.
# R2_BACKUP_ENDPOINT/ACCESS_KEY_ID/SECRET_ACCESS_KEY may be left blank to
# fall back to the R2_* vars above (same Cloudflare account/key can cover
# multiple buckets) — set them only if you created a separate scoped key.
R2_BACKUP_BUCKET=
R2_BACKUP_ENDPOINT=
R2_BACKUP_ACCESS_KEY_ID=
R2_BACKUP_SECRET_ACCESS_KEY=

# Where every "something is broken" alert email goes: cmd/db_backup
# (failure), cmd/uptime_check (down/recovered), and the main web server
# itself (a 5xx or recovered panic from a real request — see
# internal/handler/errors.go). Falls back to admin@pdlife.app if unset.
ADMIN_ALERT_EMAIL=

# cmd/news_ingest_pubmed + cmd/news_ingest_nephrothai only — not read by
# the main web server. PROVIDER is tried first, FALLBACK_PROVIDER only if
# that call fails. Each provider's own API key/model var below is
# required whenever that provider is selected as PROVIDER or
# FALLBACK_PROVIDER.
PROVIDER=openai
FALLBACK_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=

# OPENAI_API_KEY above is also used directly for feature-image generation
# (internal/newsimage, model gpt-image-2) regardless of which provider
# PROVIDER/FALLBACK_PROVIDER select for text — image generation is
# OpenAI-only. Reuses the R2_* vars above (path: pdlife/news/{source}/{external_id}.png).
